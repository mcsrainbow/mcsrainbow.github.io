      <link>https://blog.heylinux.com/2007/12/%E5%A6%82%E4%BD%95%E5%B0%86usb%E7%A7%BB%E5%8A%A8%E7%A1%AC%E7%9B%98%E5%81%9A%E6%88%90dos%E5%90%AF%E5%8A%A8%E7%9B%98/</link>
