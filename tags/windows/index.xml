    <item>
      <title>如何将USB移动硬盘做成DOS启动盘</title>
      <link>https://blog.heylinux.com/2007/12/%E5%A6%82%E4%BD%95%E5%B0%86usb%E7%A7%BB%E5%8A%A8%E7%A1%AC%E7%9B%98%E5%81%9A%E6%88%90dos%E5%90%AF%E5%8A%A8%E7%9B%98/</link>
      <pubDate>Sun, 30 Dec 2007 00:00:00 +0000</pubDate>
      
      <guid>https://blog.heylinux.com/2007/12/%E5%A6%82%E4%BD%95%E5%B0%86usb%E7%A7%BB%E5%8A%A8%E7%A1%AC%E7%9B%98%E5%81%9A%E6%88%90dos%E5%90%AF%E5%8A%A8%E7%9B%98/</guid>
      <description>&lt;p&gt;&lt;strong&gt;准备工具&lt;/strong&gt;：&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;
&lt;p&gt;一把螺丝刀；&lt;/p&gt;
&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;一台带有光驱的台式电脑；&lt;/p&gt;
&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;一张带有DOS工具的windows安装/恢复光盘；&lt;/p&gt;
&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;一个带有USB接口的移动硬盘。&lt;/p&gt;
&lt;/li&gt;
&lt;/ul&gt;</description>
    </item>
    
