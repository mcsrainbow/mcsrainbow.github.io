    <item>
      <title>回忆我在汶川大地震中的经历</title>
      <link>https://blog.heylinux.com/2008/05/%E5%9B%9E%E5%BF%86%E6%88%91%E5%9C%A8%E6%B1%B6%E5%B7%9D%E5%A4%A7%E5%9C%B0%E9%9C%87%E4%B8%AD%E7%9A%84%E7%BB%8F%E5%8E%86/</link>
